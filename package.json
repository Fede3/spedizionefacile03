{
	"name": "spediamofacile",
	"private": true,
	"version": "2.0.0-rewrite",
	"description": "SpediamoFacile - Inertia 2 monolite (Laravel 11 + Vue 3.5 + Tailwind 4)",
	"engines": {
		"node": ">=20",
		"npm": ">=9"
	},
	"scripts": {
		"prepare": "husky",
		"commitlint": "commitlint --edit",
		"dev": "cd apps/api && npm run dev",
		"build": "cd apps/api && npm run build",
		"serve": "cd apps/api && php artisan serve",
		"test": "cd apps/api && php artisan test"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.6.1",
		"@commitlint/config-conventional": "^19.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.2.11"
	}
}
