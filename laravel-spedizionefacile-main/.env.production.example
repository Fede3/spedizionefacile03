# =============================================================================
# VARIABILI D'AMBIENTE — PRODUZIONE
# =============================================================================
# Copia questo file come .env sul server e compila TUTTI i valori.
# I segnaposto tra parentesi angolari <...> DEVONO essere sostituiti.
# =============================================================================

# ------------------------------------------------------------------
# Applicazione
# ------------------------------------------------------------------
APP_NAME=SpediamoFacile
APP_ENV=production
# Genera con: php artisan key:generate
APP_KEY=
# MAI true in produzione — espone stack trace e dati sensibili
APP_DEBUG=false
APP_TIMEZONE=Europe/Rome
# URL pubblico del backend (quello che Caddy espone)
APP_URL=https://spediamofacile.it
# URL del frontend Nuxt (serve per email, link di reset password, ecc.)
APP_FRONTEND_URL=https://spediamofacile.it

APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Costo computazionale hash password — 12 e' un buon default per produzione
BCRYPT_ROUNDS=12

# ------------------------------------------------------------------
# Log — in produzione "stack" scrive su file + canale aggiuntivo
# ------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Usa "warning" o "error" in produzione per ridurre rumore
LOG_LEVEL=warning

# ------------------------------------------------------------------
# Database MySQL
# ------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Nome del database — crealo prima: CREATE DATABASE spediamofacile;
DB_DATABASE=spediamofacile
DB_USERNAME=<UTENTE_MYSQL>
DB_PASSWORD=<PASSWORD_MYSQL>

# ------------------------------------------------------------------
# Sessione — cookie sicuro via HTTPS
# ------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Dominio del cookie — punto davanti per includere sottodomini
SESSION_DOMAIN=.spediamofacile.it
# OBBLIGATORIO in produzione — i cookie viaggiano solo su HTTPS
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ------------------------------------------------------------------
# Cache, code, filesystem
# ------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Redis per le code — elabora job in background (email, notifiche)
# Richiede: sudo apt install redis-server
QUEUE_CONNECTION=redis
# Redis anche per la cache — piu' veloce di "file"
CACHE_STORE=redis
CACHE_PREFIX=spediamofacile_

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
# Imposta una password se Redis e' esposto in rete
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------
# Sanctum — autenticazione SPA con cookie
# ------------------------------------------------------------------
# Domini che possono inviare cookie di sessione (senza https://)
SANCTUM_STATEFUL_DOMAINS=spediamofacile.it,www.spediamofacile.it

# ------------------------------------------------------------------
# CORS — origini ammesse per richieste con credenziali
# ------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://spediamofacile.it,https://www.spediamofacile.it

# ------------------------------------------------------------------
# Email — Resend (SMTP)
# ------------------------------------------------------------------
# 1. Registrati su https://resend.com
# 2. Verifica il dominio spediamofacileaccount.com (o il tuo)
# 3. Crea API Key e incollala come MAIL_PASSWORD
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=<RE_API_KEY_RESEND>
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@spediamofacileaccount.com"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------------
# BRT (Bartolini) — Credenziali spedizioni
# ------------------------------------------------------------------
# Fornite dal tuo referente BRT Business
BRT_CLIENT_ID=<ID_CLIENTE_BRT>
BRT_PASSWORD=<PASSWORD_BRT>
BRT_API_URL=https://api.brt.it/rest/v1/shipments
BRT_PUDO_API_URL=https://api.brt.it
BRT_PUDO_TOKEN=<TOKEN_PUDO_BRT>
# Filiale di partenza (codice numerico BRT)
BRT_DEPARTURE_DEPOT=0
# In produzione DEVE essere true — verifica certificati SSL
BRT_VERIFY_SSL=true

# ------------------------------------------------------------------
# Stripe — Pagamenti LIVE
# ------------------------------------------------------------------
# Usa le chiavi LIVE (non test!) dal dashboard Stripe
# https://dashboard.stripe.com/apikeys
STRIPE_KEY=pk_live_<CHIAVE_PUBBLICA_STRIPE>
STRIPE_SECRET=sk_live_<CHIAVE_SEGRETA_STRIPE>
STRIPE_CLIENT_ID=<CLIENT_ID_STRIPE_CONNECT>
# Webhook: crea endpoint su https://dashboard.stripe.com/webhooks
# URL webhook: https://spediamofacile.it/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_<SEGRETO_WEBHOOK_STRIPE>

# ------------------------------------------------------------------
# Google OAuth (opzionale — lascia vuoto per disattivare)
# ------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

# ------------------------------------------------------------------
# Facebook OAuth (opzionale — lascia vuoto per disattivare)
# ------------------------------------------------------------------
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=${APP_URL}/auth/facebook/callback

# ------------------------------------------------------------------
# Apple OAuth (opzionale — lascia vuoto per disattivare)
# ------------------------------------------------------------------
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=${APP_URL}/auth/apple/callback
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ------------------------------------------------------------------
# AWS S3 (opzionale — per storage file su cloud)
# ------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
