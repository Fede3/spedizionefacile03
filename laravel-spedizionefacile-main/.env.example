APP_NAME=SpediamoFacile
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Rome
APP_URL=http://127.0.0.1:8000
APP_FRONTEND_URL=http://127.0.0.1:3001

APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================
# EMAIL - Resend (SMTP)
# ============================================================
# 1. Registrati su https://resend.com (gratis)
# 2. Crea un'API Key nella dashboard
# 3. Incolla la chiave (re_...) come MAIL_PASSWORD
# Piano gratuito: 3.000 email/mese, 100/giorno
# Per dev locale senza email: usa MAIL_MAILER=log
# ============================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=re_INCOLLA_QUI_LA_TUA_API_KEY
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@spediamofacileaccount.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SPA/Sanctum (origine unica Caddy su 8787 + direct access on 8000/3001)
SANCTUM_STATEFUL_DOMAINS=127.0.0.1:8787,localhost:8787,127.0.0.1:3001,localhost:3001,127.0.0.1:8000,localhost:8000,*.trycloudflare.com

# CORS (origini ammesse per richieste con credenziali)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8787,http://localhost:8787,http://127.0.0.1:3001,http://localhost:3001,http://127.0.0.1:8000,http://localhost:8000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=${APP_URL}/auth/facebook/callback

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=${APP_URL}/auth/apple/callback
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=
