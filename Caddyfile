# =============================================================================
# CADDYFILE - Reverse Proxy per sviluppo locale
# =============================================================================
#
# SCOPO: Caddy fa da "smistatore" (reverse proxy) che riceve TUTTE le richieste
#        sulla porta 8787 e le smista al backend o al frontend giusto.
#
# COME FUNZIONA:
#   Browser → Caddy (:8787) → Laravel (:8000) per le API
#                            → Nuxt (:3001) per le pagine web
#
# PERCHE' SERVE:
#   Senza Caddy, il frontend (porta 3001) e il backend (porta 8000) sarebbero
#   su porte diverse = "origini" diverse per il browser. Questo causerebbe problemi
#   con i cookie di sessione (cross-origin). Con Caddy, tutto passa dalla porta 8787
#   e il browser vede un'unica origine = i cookie funzionano perfettamente.
#
# HEADER IMPORTANTI:
#   - X-Forwarded-Host: dice al backend qual era l'hostname originale della richiesta
#   - X-Forwarded-Proto: dice al backend se il client usava HTTP o HTTPS
#     (Caddy riceve in HTTP, ma se c'e' Cloudflare davanti, il client usava HTTPS)
#
# FILE CORRELATI:
#   - Caddyfile.trycloudflare — versione per Cloudflare tunnel (forza HTTPS)
#   - bootstrap/app.php — trustProxies che fa leggere a Laravel questi header
# =============================================================================

:8787 {
  # Comprime le risposte con gzip per velocizzare il caricamento
  encode gzip

  # Definisce quali percorsi vanno al backend Laravel (API, autenticazione, file)
  # Tutto cio' che inizia con /api/, /sanctum/, /storage/ o /auth/ va a Laravel
  @api path /api/* /sanctum/* /storage/* /auth/*

  # Richieste API → Laravel (porta 8000)
  # Inoltra gli header del proxy cosi' Laravel sa l'host e il protocollo originali
  reverse_proxy @api 127.0.0.1:8000 {
    header_up X-Forwarded-Host "{http.request.host}"
    header_up X-Forwarded-Proto "{http.request.scheme}"
  }

  # Tutto il resto → Nuxt frontend (porta 3001)
  # Host "localhost:3001" serve a Nuxt per riconoscere la richiesta come valida
  reverse_proxy 127.0.0.1:3001 {
    header_up Host "localhost:3001"
    header_up X-Forwarded-Host "{http.request.host}"
    header_up X-Forwarded-Proto "{http.request.scheme}"
  }
}
