#!/usr/bin/env sh

# Fast-lane: se non c'è nessun file staged (es. merge commit), salta.
if git diff --cached --name-only --diff-filter=ACMR | read -r _; then
	:
else
	exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"

# --- Nuxt: lint-staged (ESLint + Prettier solo sui file staged) ---
NUXT_STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^apps/web/' || true)
if [ -n "$NUXT_STAGED" ]; then
	echo "[husky] pre-commit: lint-staged (Nuxt)"
	cd "$ROOT/apps/web" || exit 1
	npx --no-install lint-staged || exit 1
	cd "$ROOT" || exit 1
fi

# --- Laravel: Pint in dirty mode (formatta solo i file staged) ---
# Backend Laravel sta alla ROOT del repo (non più apps/api).
LARAVEL_STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^(app|routes|database|tests|config|bootstrap)/.*\.php$' || true)
if [ -n "$LARAVEL_STAGED" ]; then
	echo "[husky] pre-commit: Laravel Pint (--dirty)"
	cd "$ROOT" || exit 1
	if [ -x vendor/bin/pint ]; then
		vendor/bin/pint --dirty --test || {
			echo "[husky] Pint ha trovato file PHP non formattati. Esegui: vendor/bin/pint --dirty"
			exit 1
		}
	else
		echo "[husky] Pint non installato (vendor/bin/pint mancante) — skip."
	fi
fi

exit 0
