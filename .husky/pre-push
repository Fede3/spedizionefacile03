#!/usr/bin/env sh

# Pre-push: gate piu' pesante. Lanciato una volta per push, non per commit.
# Obiettivo: impedire che arrivi su remote codice rotto. E2E restano a CI.

ROOT="$(git rev-parse --show-toplevel)"

# --- Frontend: build smoke ---
cd "$ROOT/apps/web" || exit 1
echo "[husky] pre-push: Nuxt build"
npm run build || {
	echo "[husky] build fallito — fixa prima del push."
	exit 1
}

# --- Backend: unit test ---
# Backend Laravel sta alla ROOT del repo (non più apps/api).
cd "$ROOT" || exit 1
if [ -f artisan ]; then
	echo "[husky] pre-push: php artisan test --testsuite=Unit"
	php artisan test --testsuite=Unit --stop-on-failure || {
		echo "[husky] unit test falliti — fixa prima del push."
		exit 1
	}
else
	echo "[husky] Laravel non installato — skip."
fi

exit 0
