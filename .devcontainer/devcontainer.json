{
  "name": "tuttoinsieme",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "postCreateCommand": "bash -lc \"./scripts/avvia-tutto.sh\"",
  "postStartCommand": "bash -lc \"./scripts/avvia-tutto.sh\"",
  "forwardPorts": [
    3001,
    8000
  ],
  "portsAttributes": {
    "3001": {
      "label": "Nuxt",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "8000": {
      "label": "Laravel",
      "visibility": "public"
    }
  },
  "containerEnv": {}
}
